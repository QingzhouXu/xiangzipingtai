# ============================================================
# LLM 后端选择: ollama | dashscope | openai | mock
# ============================================================
LLM_BACKEND=ollama

# ============================================================
# Flask 服务配置
# ============================================================
PORT=5000
FLASK_SECRET_KEY=ai-customer-service-demo

# ============================================================
# Ollama 本地模型（LLM_BACKEND=ollama 时生效）
# ============================================================
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3.5:4b

# ============================================================
# 阿里云 DashScope 云端模型（LLM_BACKEND=dashscope 时生效）
# 获取 API Key: https://bailian.console.aliyun.com/
# ============================================================
DASHSCOPE_API_KEY=your_openai_api_key_here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-plus

# ============================================================
# OpenAI 兼容接口（如 DeepSeek、硅基流动、智谱等第三方 API）
# LLM_BACKEND=openai 时生效，BASE_URL 替换为对应厂商地址
# ============================================================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
